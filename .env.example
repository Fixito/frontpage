# Database (Neon)
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better Auth
# Generate a secret: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated list of allowed origins (for CORS)
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# AI (Google Gemini)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Guest Demo (run 'pnpm seed' once and paste the output here)
GUEST_DEMO_USER_ID=

# Email (Resend) — used for password reset
# Get free key at resend.com (100 emails/day free)
RESEND_API_KEY=re_...
# Must be a Resend-verified sender address or domain.
# For testing without a domain: use onboarding@resend.dev (sandbox — emails only delivered to your Resend account email)
# For production: verify your domain at resend.com/domains and use noreply@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev
