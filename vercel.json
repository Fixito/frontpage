{
	"buildCommand": "pnpm build",
	"installCommand": "pnpm install",
	"framework": null,
	"env": {
		"NITRO_PRESET": "vercel"
	},
	"headers": [
		{
			"source": "/_build/assets/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	]
}
